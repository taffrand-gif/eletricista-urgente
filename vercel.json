{
 "cleanUrls": true,
 "trailingSlash": false,
 "outputDirectory": ".",
 "rewrites": [
  {
   "source": "/(.*)",
   "destination": "/$1.html"
  }
 ],
 "headers": [
  {
   "source": "/paa/(.*)",
   "headers": [
    {
     "key": "X-Robots-Tag",
     "value": "noindex, nofollow"
    },
    {
     "key": "Cache-Control",
     "value": "public, max-age=0, must-revalidate"
    }
   ]
  },
  {
   "source": "/(.*)electrician(.*)",
   "headers": [
    {
     "key": "X-Robots-Tag",
     "value": "noindex, nofollow"
    }
